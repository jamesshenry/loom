{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "LoomSettings",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "workspace": {
      "$ref": "#/definitions/WorkspaceSettings"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ArtifactSettings"
      }
    },
    "run": {
      "$ref": "#/definitions/ExecutionOptions"
    },
    "$schema": {
      "type": "string",
      "description": "The URL to the JSON schema for this file."
    }
  },
  "definitions": {
    "WorkspaceSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solution"
      ],
      "properties": {
        "solution": {
          "type": "string",
          "description": "Path to the solution file.",
          "minLength": 1
        },
        "artifactsPath": {
          "type": "string"
        }
      }
    },
    "ArtifactSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "type"
      ],
      "properties": {
        "project": {
          "type": "string",
          "description": "Path to the project file.",
          "minLength": 1
        },
        "type": {
          "description": "Artifact type (nuget, dotnet-publish, velopack).",
          "oneOf": [
            {
              "$ref": "#/definitions/ArtifactType"
            }
          ]
        },
        "rid": {
          "description": "Runtime identifier.",
          "$ref": "#/definitions/RuntimeIdentifier"
        },
        "version": {
          "type": "string"
        },
        "velopackId": {
          "type": "string"
        }
      }
    },
    "ArtifactType": {
      "type": "string",
      "description": "",
      "x-enumNames": [
        "Nuget",
        "Executable",
        "Velopack"
      ],
      "enum": [
        "Nuget",
        "Executable",
        "Velopack"
      ]
    },
    "ExecutionOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "$ref": "#/definitions/BuildTarget"
        },
        "configuration": {
          "type": "string"
        },
        "rid": {
          "$ref": "#/definitions/RuntimeIdentifier"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "BuildTarget": {
      "type": "string",
      "description": "",
      "x-enumNames": [
        "Build",
        "Test",
        "Publish",
        "Restore",
        "Release",
        "NugetUpload",
        "Clean"
      ],
      "enum": [
        "Build",
        "Test",
        "Publish",
        "Restore",
        "Release",
        "NugetUpload",
        "Clean"
      ]
    },
    "RuntimeIdentifier": {
      "type": "string",
      "enum": [
        "win-x64",
        "win-arm64",
        "linux-x64",
        "linux-arm64",
        "osx-x64",
        "osx-arm64"
      ]
    }
  }
}